---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { Pagination } from "../components/blog/Pagination";
import { SearchArticles } from "../components/blog/SearchArticles";
import { TagsBox } from "../components/blog/TagsBox";
import { BlogCard } from "../components/blog/BlogCard";
import { Icon } from "../components/Icon";
import MainLayout from "./MainLayout.astro";

export type Props = {
  page: Page<CollectionEntry<"blog">>;
  allTags: string[];
  currentTag?: string;
  showSearch?: boolean;
};

const { page, allTags, currentTag, showSearch = true } = Astro.props;
---

<MainLayout>
  <slot name="header" />

  {
    showSearch && (
      <div class="mb-4 space-y-4 py-3">
        <div class="relative mx-auto max-w-md">
          <SearchArticles client:load />
        </div>
      </div>
    )
  }

  <div class="sticky top-16 z-40 py-6 backdrop-blur-lg">
    <TagsBox tags={allTags} currentTag={currentTag} />
  </div>

  <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
    {page.data.map((post) => <BlogCard post={post} currentTag={currentTag} />)}
  </div>

  {
    page.data.length === 0 && (
      <div class="py-16 text-center">
        <Icon
          icon="mdi:file-document-outline"
          className="mb-4 text-6xl opacity-20"
          width="1.5em"
          height="1.5em"
        />
        <h2 class="mb-2 text-xl font-semibold text-gray-900">
          記事が見つかりません
        </h2>
        <p class="text-gray-600">
          <slot name="empty-message">記事がありません</slot>
        </p>
      </div>
    )
  }

  <div class="mt-12">
    <Pagination prev={page.url.prev} next={page.url.next} />
  </div>
</MainLayout>
