---
import { writeFile, mkdir } from "node:fs/promises";
import { join } from "node:path";
import { formatDate } from "../utils/formatDate";
import Layout from "./Layout.astro";
import TwoPaneLayout from "../layouts/TwoPaneLayout.astro";
import { TableOfContents } from "../components/blog/TableOfContents";
import { ShareButtons } from "../components/blog/ShareButtons";
import { getBlogs, parseTags } from "../utils/blog/index";
import { Link } from "../components/Link";
import { HATENA_BLOG_ENTRY_URL } from "../constants";
import { Badge } from "../components/blog/Badge";
import { Card } from "../components/Card";
import { CardContent } from "../components/CardContent";
import { CardTitle } from "../components/CardTitle";
import { Image } from "../components/Image";
import { Icon } from "../components/Icon";
import { References } from "../components/blog/References";
import { fetchReferences } from "../utils/blog/fetchReferences";
import type { CollectionEntry } from "astro:content";
import type { MarkdownLayoutProps } from "astro";
import { generateOgImage } from "../utils/ogp";
import "../styles/blog.css";

const { frontmatter, headings: originalHeadings } =
  Astro.props as MarkdownLayoutProps<CollectionEntry<"blog">["data"]>;

// 参考文献がある場合は目次に追加
const headings =
  frontmatter.references && frontmatter.references.length > 0
    ? [
        ...originalHeadings,
        { depth: 2, slug: "references", text: "参考リンク" },
      ]
    : originalHeadings;
const date = formatDate(new Date(frontmatter.date));
const diffDate =
  (new Date().getTime() - new Date(frontmatter.date).getTime()) /
  (60 * 60 * 1000 * 24);
const { title, url: tmpUrl, description, tags } = frontmatter;

/**
 * Resolve the post URL from frontmatter or fallback to Astro.url.pathname
 * Handles file paths like "/path/to/content/blog/post.mdx" correctly
 */
function resolvePostUrl(
  frontmatterUrl: string | undefined,
  astroUrl: URL,
): string {
  if (!frontmatterUrl) {
    return astroUrl.pathname;
  }

  // Remove file extension (.mdx or .md)
  const withoutExtension = frontmatterUrl.replace(/\.mdx?$/, "");

  // Extract path after /content/blog/ using proper regex
  const match = withoutExtension.match(/\/content\/blog\/(.+)$/);
  if (match && match[1]) {
    return `/blog/${match[1]}`;
  }

  // If no match, fallback to Astro URL
  return astroUrl.pathname;
}

const url = resolvePostUrl(tmpUrl, Astro.url);

// HMRで重くなるため、dev環境ではglobをさせない
const posts =
  import.meta.env.NODE_ENV !== "development" ? await getBlogs() : [];
const index = posts.findIndex(
  ({ slug }) =>
    slug ===
    Astro.url.pathname
      .replace(/\/blog\//, "")
      .replace(/\/$/, "" /* for prod */),
);

const githubUrl = `https://github.com/hiroppy/site/tree/main/src/content/${Astro.url.pathname.replace(
  /(^\/|\/$)/g,
  "",
)}.mdx`;

// Get related posts
const relatedPosts = posts
  .filter(
    (blog) =>
      blog.slug !==
      Astro.url.pathname.replace(/\/blog\//, "").replace(/\/$/, ""),
  )
  .filter((blog) => {
    const currentTags = parseTags(tags);
    const blogTags = parseTags(blog.data.tags);
    return currentTags.some((tag: string) => blogTags.includes(tag));
  })
  .slice(0, 2);

const ogImageFileName = "og.png";
const ogImageDistRelativePath = `../../${url.replace(/^\//, "")}`;
const ogImageDistAbsolutePath = join(ogImageDistRelativePath, ogImageFileName);

if (import.meta.env.PROD || process.env.NODE_ENV === "test") {
  const buf = await generateOgImage(title, tags.split(","));
  const fileDir = join(process.cwd(), "dist/client", url.replace(/^\//, ""));

  await mkdir(fileDir, {
    recursive: true,
  });
  await writeFile(join(fileDir, ogImageFileName), new Uint8Array(buf));
}

// Fetch references data
const referencesWithTitles =
  frontmatter.references && frontmatter.references.length > 0
    ? await fetchReferences(frontmatter.references)
    : [];
---

<Layout
  title={title}
  description={description}
  image={ogImageDistAbsolutePath}
  isOptimizedImage={false}
  fullscreen
>
  <TwoPaneLayout>
    <aside
      slot="sidebar"
      class="bg-bg hidden h-full w-72 shrink-0 border-r border-gray-200 lg:block"
    >
      <div class="flex h-full flex-col">
        <div class="shrink-0 px-6 pt-10 pb-4">
          <h2 class="flex items-center text-sm font-semibold text-gray-900">
            <Icon
              icon="mdi:table-of-contents"
              className="mr-2"
              width="16"
              height="16"
            />
            目次
          </h2>
        </div>
        <div class="flex-1 overflow-y-auto px-6 pb-6">
          <TableOfContents headings={headings} />
        </div>
        <div
          class="flex h-20 shrink-0 items-center border-t border-gray-200 px-6"
        >
          <Link
            href="/blog"
            animation={false}
            unstyled
            className="flex items-center text-sm font-medium text-gray-600"
          >
            <Icon
              icon="mdi:arrow-left"
              className="mr-2"
              width="16"
              height="16"
            />
            blog一覧に戻る
          </Link>
        </div>
      </div>
    </aside>

    <div slot="content">
      <main class="container mx-auto max-w-7xl px-2 py-6 md:px-4 md:py-8">
        <article class="overflow-hidden rounded-2xl shadow-lg">
          <div class="relative">
            {
              frontmatter.image ? (
                <Image
                  src={frontmatter.image}
                  alt={title}
                  width={800}
                  height={400}
                  lazy={false}
                  fetchPriority="high"
                  className="h-64 w-full object-cover md:h-80"
                />
              ) : (
                <div class="flex h-64 w-full items-center justify-center bg-linear-to-br from-blue-500 to-purple-400 md:h-80" />
              )
            }
            <div
              class="absolute inset-0 bg-linear-to-t from-black/50 to-transparent"
            >
            </div>
            <div class="absolute right-4 bottom-6 left-4 md:right-8 md:left-8">
              <h1 class="mb-4 text-3xl font-bold text-white md:text-4xl">
                {title}
              </h1>
              <div class="flex items-center text-white/90">
                <Icon icon="mdi:calendar" width="16" height="16" />
                <span class="ml-2">{date}</span>
              </div>
            </div>
          </div>

          <div class="px-4 py-8 md:px-8">
            <div class="mb-4 flex items-center justify-between">
              <div class="flex flex-wrap gap-2">
                {
                  parseTags(tags).map((tag: string) => (
                    <Badge variant="secondary" className="text-sm">
                      <a
                        href={`/blog/tags/${tag}`}
                        aria-label={`${tag}タグの記事を表示`}
                      >
                        {tag}
                      </a>
                    </Badge>
                  ))
                }
              </div>
              <Link
                href={githubUrl}
                icon="mdi:github"
                variant="button"
                ariaLabel="Edit this page on GitHub">Edit</Link
              >
            </div>

            <hr class="mb-4 border-gray-200" />

            <!-- Mobile Table of Contents -->
            <details class="bg-bg mb-8 rounded-lg p-6 lg:hidden">
              <summary class="cursor-pointer font-semibold text-gray-600">
                目次
              </summary>
              <div class="mt-4">
                <TableOfContents headings={headings} />
              </div>
            </details>

            <!-- Warnings -->
            <div class="mb-8 space-y-4">
              {
                diffDate > 365 && (
                  <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4">
                    <div class="flex items-center">
                      <Icon
                        icon="mdi:alert"
                        className="mr-2 text-yellow-600"
                        width="20"
                        height="20"
                      />
                      <span class="text-sm font-medium text-yellow-800">
                        この記事は1年以上更新されていません
                      </span>
                    </div>
                  </div>
                )
              }
              {
                frontmatter.hatenaPath && (
                  <div class="rounded-lg border border-blue-200 bg-blue-50 p-4">
                    <div class="flex items-center">
                      <Icon
                        icon="mdi:check-circle"
                        className="mr-2 text-blue-600"
                        width="20"
                        height="20"
                      />
                      <span class="text-sm text-blue-800">
                        この記事は{" "}
                        <Link
                          href={`${HATENA_BLOG_ENTRY_URL}/${frontmatter.hatenaPath}`}
                          className="underline"
                        >
                          Hatena Blog
                        </Link>{" "}
                        からの移行記事です
                      </span>
                    </div>
                  </div>
                )
              }
            </div>

            <!-- Article Content -->
            <div class="prose prose-lg max-w-none">
              <slot />
            </div>

            {
              referencesWithTitles.length > 0 && (
                <References references={referencesWithTitles} />
              )
            }

            <hr class="my-8 border-gray-200" />

            <div class="mb-8">
              <div
                class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
              >
                <ShareButtons
                  url={`${Astro.site?.origin}${url!}`}
                  title={title}
                />
              </div>
            </div>
          </div>
        </article>

        {
          index !== -1 && (
            <section class="my-12">
              <h2 class="mb-6 text-xl font-bold text-gray-900">
                <Icon
                  icon="noto:open-book"
                  className="mr-2 inline-block"
                  width="20"
                  height="20"
                />
                前後の記事
              </h2>
              <div class="grid gap-6 md:grid-cols-2">
                {index !== 0 ? (
                  <Card
                    className="transition-all duration-300 hover:shadow-lg"
                    link={{
                      href: `/blog/${posts[index - 1].slug}`,
                      ariaLabel: `前の記事: ${posts[index - 1].data.title}`,
                    }}
                  >
                    <CardContent>
                      <div class="mb-2 text-xs text-gray-500">← 前の記事</div>
                      <CardTitle className="line-clamp-2 text-sm">
                        {posts[index - 1].data.title}
                      </CardTitle>
                    </CardContent>
                  </Card>
                ) : (
                  <div />
                )}
                {index !== posts.length - 1 ? (
                  <Card
                    className="transition-all duration-300 hover:shadow-lg"
                    link={{
                      href: `/blog/${posts[index + 1].slug}`,
                      ariaLabel: `次の記事: ${posts[index + 1].data.title}`,
                    }}
                  >
                    <CardContent className="text-right">
                      <div class="mb-2 text-xs text-gray-500">次の記事 →</div>
                      <CardTitle className="line-clamp-2 text-sm">
                        {posts[index + 1].data.title}
                      </CardTitle>
                    </CardContent>
                  </Card>
                ) : (
                  <div />
                )}
              </div>
            </section>
          )
        }

        <!-- Related Posts -->
        {
          relatedPosts.length > 0 && (
            <section class="my-12">
              <h2 class="mb-6 text-xl font-bold text-gray-900">
                <Icon
                  icon="mdi:link-variant"
                  className="mr-2 inline-block"
                  width="20"
                  height="20"
                />
                関連する記事
              </h2>
              <div class="grid gap-6 md:grid-cols-2">
                {relatedPosts.map((post) => (
                  <Card
                    className="transition-all duration-300 hover:shadow-lg"
                    link={{
                      href: `/blog/${post.slug}`,
                      ariaLabel: `関連記事: ${post.data.title}`,
                    }}
                  >
                    <CardContent>
                      <div class="flex items-center">
                        {post.data.image && (
                          <Image
                            src={post.data.image}
                            alt={post.data.title}
                            width={120}
                            height={80}
                            className="h-20 w-24 rounded-lg object-cover"
                          />
                        )}
                        {!post.data.image && (
                          <div class="flex h-20 w-24 items-center justify-center rounded-lg bg-linear-to-br from-blue-50 to-purple-50">
                            <Icon
                              icon="mdi:file-document-outline"
                              className="text-2xl opacity-30"
                              width="1em"
                              height="1em"
                            />
                          </div>
                        )}
                        <div class="flex-1 pl-4">
                          <Badge variant="secondary" className="mb-2 text-xs">
                            {parseTags(post.data.tags)?.[0] || "記事"}
                          </Badge>
                          <CardTitle className="mb-2 line-clamp-2 text-sm">
                            {post.data.title}
                          </CardTitle>
                          <p class="text-xs text-gray-500">
                            {formatDate(post.data.date)}
                          </p>
                        </div>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            </section>
          )
        }
      </main>
    </div>
  </TwoPaneLayout>
</Layout>

<script>
  let cleanupToc: (() => void) | null = null;

  const runWhenIdle = (cb: () => void) => {
    if ("requestIdleCallback" in window) {
      (window as any).requestIdleCallback(cb, { timeout: 500 });
    } else {
      // @ts-expect-error TODO: refactor
      window.setTimeout(cb, 200);
    }
  };

  // Table of Contents active section highlighting
  function initializeTocHighlighting() {
    cleanupToc?.();

    const tocLinks = Array.from(
      document.querySelectorAll("[data-toc-link]"),
    ) as HTMLElement[];
    const headings = Array.from(
      document.querySelectorAll("h1[id], h2[id], h3[id]"),
    );

    if (!tocLinks.length || !headings.length) {
      cleanupToc = null;
      return;
    }

    let currentActiveId = "";
    let isHashChangeHandled = false;

    function setActiveLink(id: string) {
      if (id === currentActiveId) return;
      currentActiveId = id;

      // Remove active class from all links
      tocLinks.forEach((link) => {
        link.classList.remove("bg-blue-100", "text-blue-700");
      });

      // Add active class to current link
      if (currentActiveId) {
        const activeLink = document.querySelector<HTMLElement>(
          `[data-toc-link="${currentActiveId}"]`,
        );
        if (activeLink) {
          activeLink.classList.add("bg-blue-100", "text-blue-700");
        }
      }
    }

    // Check initial hash on page load
    function checkInitialHash() {
      const hash = window.location.hash.slice(1); // Remove #
      if (hash) {
        // Small delay to ensure DOM is ready
        setTimeout(() => {
          const element = document.getElementById(hash);
          if (element) {
            setActiveLink(hash);
          }
        }, 100);
      }
    }

    const handleHashChange = () => {
      isHashChangeHandled = true;
      const hash = window.location.hash.slice(1);
      if (hash) {
        setActiveLink(hash);
      }
    };

    const handleLinkClick = (event: Event) => {
      const target = event.currentTarget as HTMLElement;
      const targetId = target.getAttribute("data-toc-link");
      if (targetId) {
        setActiveLink(targetId);
      }
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setActiveLink(entry.target.id);
          }
        });
      },
      {
        rootMargin: "-20% 0px -60% 0px",
        threshold: 0.1,
      },
    );

    headings.forEach((heading) => {
      observer.observe(heading);
    });

    // Listen for hash changes (when clicking TOC links or anchor links)
    window.addEventListener("hashchange", handleHashChange);

    // Add click listeners to TOC links
    tocLinks.forEach((link) => {
      link.addEventListener("click", handleLinkClick);
    });

    // Check initial hash
    checkInitialHash();

    cleanupToc = () => {
      observer.disconnect();
      window.removeEventListener("hashchange", handleHashChange);
      tocLinks.forEach((link) => {
        link.removeEventListener("click", handleLinkClick);
      });
      if (isHashChangeHandled) {
        isHashChangeHandled = false;
      }
    };
  }

  const scheduleTocSetup = () => runWhenIdle(initializeTocHighlighting);

  // Initialize on page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleTocSetup, {
      once: true,
    });
  } else {
    scheduleTocSetup();
  }

  // Initialize on Astro page transitions
  document.addEventListener("astro:page-load", scheduleTocSetup);
</script>
