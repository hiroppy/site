---
import { writeFile, mkdir } from "node:fs/promises";
import { join } from "node:path";
import Layout from "./Layout.astro";
import { Sidebar } from "../components/Sidebar.tsx";
import { Footer } from "../components/Footer";
import { Header } from "../components/Header";
import { generatePageOgImage } from "../utils/ogp";

export type Props = {
  title?: string;
  description?: string;
  image?: string;
  isOptimizedImage?: boolean;
  pageType?: string;
};

const currentPath = Astro.url?.pathname || "";
const { title, description, image, isOptimizedImage, pageType } = Astro.props;

// Generate OG image if title and pageType are provided and no custom image is set
let ogImagePath = image;

if (!image && title && pageType) {
  const ogImageFileName = "og.png";
  const url = Astro.url.pathname.replace(/\/$/, "") || "/";
  ogImagePath = url === "/" ? "/og.png" : `${url}/og.png`;

  // Generate OG image in production or test mode
  if (import.meta.env.PROD || process.env.NODE_ENV === "test") {
    const buf = await generatePageOgImage(title, pageType, description);
    // Create absolute path to client directory
    const distClientDir = join(process.cwd(), "dist/client");
    const fileDir = join(distClientDir, url === "/" ? "" : url);

    await mkdir(fileDir, {
      recursive: true,
    });
    await writeFile(join(fileDir, ogImageFileName), new Uint8Array(buf));
  }
}
---

<Layout
  title={title}
  description={description}
  image={ogImagePath}
  isOptimizedImage={isOptimizedImage ?? false}
  showHeader={false}
  showFooter={false}
>
  <!-- モバイル用グローバルヘッダー -->
  <div class="mobile-header md:hidden">
    <Header currentPath={currentPath} client:idle />
  </div>
  <div class="wrapper">
    <div class="hidden md:block">
      <Sidebar currentPath={currentPath} />
    </div>
    <main class="content">
      <slot />
      <Footer />
    </main>
  </div>
</Layout>

<style>
  .wrapper {
    display: flex;
    flex-direction: column;
    max-width: 1000px;
    margin: 0 auto;
    padding: 40px 24px;
    min-height: 100vh;
  }

  @media (min-width: 768px) {
    .wrapper {
      flex-direction: row;
      gap: 80px;
      padding-top: 80px;
    }

    .wrapper :global(.sidebar) {
      width: 240px;
      flex-shrink: 0;
      position: sticky;
      top: 80px;
      height: fit-content;
    }
  }

  .content {
    flex-grow: 1;
    max-width: 600px;
  }
</style>
