---
import SidebarLayout from "../../layouts/SidebarLayout.astro";
import { Section } from "../../components/Section";
import { Card } from "../../components/Card";
import { CardContent } from "../../components/CardContent";
import { CardTitle } from "../../components/CardTitle";
import { CardDescription } from "../../components/CardDescription";
import { Icon } from "../../components/Icon";

const projects = [
  {
    title: "Feedle",
    description:
      "開発者向けの技術記事収集プラットフォーム。様々なソースから技術記事を集約し、キュレーションします。",
    link: "/labs/feedle/frontend",
    icon: "mdi:rss",
    status: "Active",
    tags: ["JavaScript", "AI"],
    color: "from-blue-500 to-purple-600",
  },
];
---

<SidebarLayout
  title="Labs"
  description="実験的なプロジェクトとアイデア"
  pageType="Labs"
>
  <div class="space-y-12">
    <Section title="Current Projects" headingLevel="h1">
      <div class="grid grid-cols-2">
        {
          projects.map((project) => (
            <Card
              variant="interactive"
              className="card-lift group"
              link={{ href: project.link }}
            >
              <CardContent className="flex h-full flex-col p-6">
                <div class="mb-4 flex items-center justify-between">
                  <div
                    class={`flex h-12 w-12 items-center justify-center rounded-lg bg-gradient-to-br ${project.color}`}
                  >
                    <Icon icon={project.icon} className="text-2xl text-white" />
                  </div>
                  <span class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-800">
                    {project.status}
                  </span>
                </div>

                <CardTitle className="mb-3 text-xl">{project.title}</CardTitle>

                <CardDescription className="mb-4 flex-grow text-gray-600">
                  {project.description}
                </CardDescription>

                <div class="mt-auto flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="rounded-md bg-gray-100 px-2 py-1 text-xs text-gray-700">
                      {tag}
                    </span>
                  ))}
                </div>
              </CardContent>
            </Card>
          ))
        }
      </div>
    </Section>
  </div>
</SidebarLayout>
