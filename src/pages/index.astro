---
import SidebarLayout from "../layouts/SidebarLayout.astro";
import { Section } from "../components/Section";
import { SectionContainer } from "../components/SectionContainer";
import { ProjectLinks } from "../components/ProjectLink";
import { Link } from "../components/Link";
import { Avatar } from "../components/Avatar";
import { MediaListItem } from "../components/MediaListItem";
import { ListContainer } from "../components/ListContainer";
import articlesData from "../../node_modules/hiroppy/generated/media.json";
import talksData from "../../node_modules/hiroppy/generated/talks.json";
import podcastsData from "../../node_modules/hiroppy/generated/podcasts.json";
import sponsors from "../../node_modules/hiroppy/generated/sponsors.json";
import repos from "../../node_modules/hiroppy/generated/repos.json";
import { getStarCount } from "../utils/github";

type MediaItem = {
  title: string;
  url: string;
  publishedAt: string;
  category: string;
};

const allMedia: MediaItem[] = [
  ...articlesData.map((item) => ({ ...item, category: "Article" })),
  ...talksData.map((item) => ({ ...item, category: "Talk" })),
  ...podcastsData.map((item) => ({ ...item, category: "Podcast" })),
]
  .sort(
    (a, b) =>
      new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime(),
  )
  .slice(0, 3);

const reposWithStars = await Promise.all(
  repos.hot.slice(0, 3).map(async (repo) => {
    const [, , , owner, repoName] = repo.url.split("/");
    return {
      ...repo,
      image: repo.image?.startsWith("http")
        ? repo.image
        : `https://avatars.githubusercontent.com/${owner}`,
      stars: await getStarCount(owner, repoName),
    };
  }),
);
---

<SidebarLayout
  title="hiroppy - Web Engineer"
  description="Web Engineer in Tokyo. Likes Open Source, Sauna, and Games."
  pageType="Home"
>
  <SectionContainer>
    <Section title="Recent Updates" headingLevel="h1">
      <ListContainer>
        {
          allMedia.map(({ url, title, publishedAt, category }) => (
            <MediaListItem
              url={url}
              title={title}
              publishedAt={publishedAt}
              category={category}
            />
          ))
        }
      </ListContainer>
    </Section>
    <Section title="Works / OSS">
      <ProjectLinks projects={reposWithStars} />
    </Section>
    <Section title="Thanks / Sponsors">
      <div
        class="grid grid-cols-[repeat(auto-fill,minmax(140px,1fr))] gap-4 pt-2"
      >
        {
          [...sponsors.current, ...sponsors.past].map(
            ({ name, avatar, href }) => (
              <Link
                href={
                  href?.includes("https://docs.github.com/sponsors")
                    ? "https://github.com"
                    : (href ?? "https://github.com")
                }
                unstyled
                className="border-line text-text-sub inline-flex items-center gap-2 rounded border px-3 py-2 text-base font-medium no-underline transition-colors hover:bg-gray-100"
              >
                {avatar && <Avatar src={avatar} alt="" size="xs" />}
                <span>{name ?? "Private user"}</span>
              </Link>
            ),
          )
        }
      </div>
    </Section>
  </SectionContainer>
</SidebarLayout>
