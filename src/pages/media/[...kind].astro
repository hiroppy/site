---
import SidebarLayout from "../../layouts/SidebarLayout.astro";
import { Section } from "../../components/Section";
import { FilterTabs } from "../../components/FilterTabs";
import { MediaListItem } from "../../components/MediaListItem";
import { ListContainer } from "../../components/ListContainer";
import { HATENA_BLOG_URL, type MediaType } from "../../constants";
import { sortByDate } from "../../utils/sortItems";

type Kind = "articles" | "talks" | "podcasts" | undefined;

type DataItem = {
  title: string;
  url: string;
  publishedAt: string;
  category: string;
  siteUrl?: string;
  icon: string;
  prefixForTitle: string;
};

export function getStaticPaths(): Array<{ params: { kind: Kind } }> {
  return [
    { params: { kind: undefined } },
    { params: { kind: "articles" } },
    { params: { kind: "talks" } },
    { params: { kind: "podcasts" } },
  ];
}

const { kind } = Astro.params;

// Map kind to data file name
function getDataKind(kind: Kind): "media" | "talks" | "podcasts" {
  return kind === "articles" ? "media" : kind || "media";
}

const items: DataItem[] = await (async () => {
  if (!kind) {
    return sortByDate(
      [
        ...(await getData("talks")),
        ...(await getData("articles")),
        ...(await getData("podcasts")),
      ],
      (item) => item.publishedAt,
    );
  }
  return await getData(kind);
})();

async function getData(kind: Exclude<Kind, undefined>) {
  const dataKind = getDataKind(kind);
  const res = (
    await import(`../../../node_modules/hiroppy/generated/${dataKind}.json`)
  ).default.map((item: Record<string, string>) => ({
    ...item,
    icon: getMediaIcon(dataKind),
    prefixForTitle: getPrefixForTitle(dataKind),
    category: getCategoryLabel(dataKind),
  }));

  if (dataKind === "media") {
    return res.filter(({ siteUrl }: DataItem) => {
      return !(
        siteUrl?.startsWith(import.meta.env.SITE) ||
        siteUrl?.startsWith(HATENA_BLOG_URL)
      );
    });
  }

  return res;
}

function getCategoryLabel(type: "media" | "talks" | "podcasts"): string {
  switch (type) {
    case "media":
      return "Article";
    case "talks":
      return "Talk";
    case "podcasts":
      return "Podcast";
  }
}

function getMediaIcon(type: MediaType) {
  switch (type) {
    case "media":
      return "mdi:typewriter";
    case "podcasts":
      return "mdi:podcast";
    case "talks":
      return "mdi:presentation";
    default:
      return "mdi:help-circle";
  }
}

function getPrefixForTitle(type: MediaType) {
  switch (type) {
    case "media":
      return "Posted";
    case "podcasts":
    case "talks":
      return "Talked";
    default:
      return "Unknown";
  }
}

function getKindLabel(kind: Kind): string {
  switch (kind) {
    case undefined:
      return "All";
    case "articles":
      return "Article";
    case "talks":
      return "Talk";
    case "podcasts":
      return "Podcast";
    default:
      return kind;
  }
}

function getKindPath(kind: Kind): string {
  return kind ? `/media/${kind}` : "/media";
}

// Prepare filter tabs
const filterTabs = [undefined, "articles", "talks", "podcasts"].map(
  (filterKind) => ({
    value: filterKind as Kind,
    label: getKindLabel(filterKind as Kind),
    href: getKindPath(filterKind as Kind),
  }),
);
---

<SidebarLayout
  title={`Media & Activities${kind ? ` / ${getKindLabel(kind)}` : ""}`}
  description="登壇・プレス・ポッドキャストなどのメディア活動"
  pageType="Media"
>
  <Section title="Media & Activities" headingLevel="h1">
    <FilterTabs tabs={filterTabs} activeValue={kind} className="mb-8" />

    {
      items.length > 0 ? (
        <ListContainer>
          {items.map(({ title, url, publishedAt, category }) => (
            <MediaListItem
              title={title}
              url={url}
              publishedAt={publishedAt}
              category={category}
            />
          ))}
        </ListContainer>
      ) : (
        <p class="text-text-sub py-12 text-center text-lg">
          該当するメディアが見つかりませんでした
        </p>
      )
    }
  </Section>
</SidebarLayout>
