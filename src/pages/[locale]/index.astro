---
import Layout from "../../layouts/Layout.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import Card from "../../components/Card.astro";
import repos from "../../../generated/repos.json";
import sponsors from "../../../generated/sponsors.json";
import articles from "../../../generated/articles.json";
import Image from "../../components/Image.astro";
import Hatena from "../../components/icons/Hatena.astro";
import Link from "../../components/Link.astro";
import { JOB_FORM } from "../../constants";
import meImage from "../../assets/images/meta/me.png";
import { useTranslations, type I18n } from "../../utils/i18n";
import Trans from "../../components/Trans.astro";

export { getStaticPaths } from "../../utils/i18n";

const i18n = {
  ja: {
    description: `
      Hiroppy (廣戸 裕大) はJavaScriptエンジニアとして、日本で働いています。
      2008年ぐらいからC++やActionScriptを中心にコードを書き始め、今はNode.jsやフロントエンドのツールについて学んでいます。
      現在は、医療系のスタートアップでVPoEとして働いたり、複数の会社で技術顧問をしています。
      OSSが好きで、Node.jsやwebpackなどにコミットしています。
    `,
    form: "こちら",
    request: `
      もし登壇、執筆、技術顧問などの依頼があれば、{{form}}からお願いします。
    `,
  },
  en: {
    description: `
      Hiroppy (Yuta Hiroto) works in Japan as a JavaScript engineer.
      I started coding mainly in C++ and ActionScript around 2008, and now I'm learning about Node.js and front-end tools.
      Currently, I work as a VPoE at a medical startup and serves as a technical advisor for several companies.
      I love OSS and contributes to projects such as Node.js and webpack.
    `,
    form: "this form",
    request: `
      If you have any requests for speaking engagements, writing, or technical consulting,
      please contact me through the {{form}}.
    `,
  },
} as const satisfies I18n;

const { t } = useTranslations(Astro.currentLocale, i18n);
---

<Layout>
  <MainLayout title="About">
    <span slot="description">
      Welcome my site 👏 I'm Yuta. I'm a javascript junkie 🍵
    </span>
    <div class="flex gap-5 flex-col sm:flex-row max-w-fit mx-auto items-center">
      <div class="m-auto min-w-fit">
        <Image
          src={meImage}
          className="rounded-full w-24 h-24 md:w-32 md:h-32 drop-shadow-[0_4px_30px_#0369a1]"
          alt="hiroppy"
          width={32 * 4}
          height={32 * 4}
          lazy={false}
        />
      </div>
      <div class="flex-auto">
        <p>
          {t("description")}
        </p>
        <br />
        <p>
          <Trans i18n={i18n} i18nKey="request">
            <slot slot="form">
              <Link
                name="request-job"
                href={JOB_FORM}
                className="text-orange-300 italic"
              >
                {t("form")}
              </Link>
            </slot>
          </Trans>
        </p>
      </div>
    </div>
    <div class="flex gap-4 mt-8 flex-col">
      <Card title="Popular Articles">
        <ol class="grid grid-cols-1 xl:grid-cols-2 gap-4">
          {
            articles
              .filter(({ hot }) => !!hot)
              .map(({ url, title, image, bookmark }) => (
                <li class="flex flex-col gap-4 items-start bg-gray-700 p-2 sm:p-3 rounded-lg justify-between">
                  <Link name={title} href={url} className="text-blue-200">
                    {title}
                  </Link>
                  <div class="flex justify-between w-full items-end text-gray-300">
                    <Image
                      src={image}
                      className="object-contain w-40 h-20"
                      alt={title}
                      width={160}
                      height={80}
                      lazy={false}
                    />
                    <div class="flex items-center text-sm gap-2">
                      <Hatena />
                      <span>{bookmark}</span>
                    </div>
                  </div>
                </li>
              ))
          }
        </ol>
      </Card>
      <Card title="Top Repositories">
        <ol class="grid grid-cols-1 xl:grid-cols-2 gap-4">
          {
            repos.hot.map(
              ({ name, image, description, url, stars, language }) => (
                <li class="flex gap-2 bg-gray-700 p-2 sm:p-3 rounded-lg">
                  <Image
                    src={image}
                    className="w-8 h-8 rounded-full"
                    alt={name}
                    width={8 * 4}
                    height={8 * 4}
                  />
                  <div class="flex flex-col text-sm flex-1 gap-2">
                    <Link
                      name={name}
                      href={url}
                      className="text-blue-200 text-lg"
                    >
                      {name}
                    </Link>
                    <span class="break-all flex-1">{description}</span>
                    <div class="flex justify-between items-center">
                      <div class="flex gap-2 items-center">
                        <svg
                          class="h-4 w-4 text-gray-300"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          stroke-width="2"
                          stroke="currentColor"
                          fill="none"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path stroke="none" d="M0 0h24v24H0z" />{" "}
                          <path d="M12 17.75l-6.172 3.245 1.179-6.873-4.993-4.867 6.9-1.002L12 2l3.086 6.253 6.9 1.002-4.993 4.867 1.179 6.873z" />
                        </svg>
                        <span>{stars.toLocaleString()}</span>
                      </div>
                      <div class="flex items-center gap-1">
                        <div
                          class={`${
                            language === "JavaScript"
                              ? "bg-javascript"
                              : language === "TypeScript"
                                ? "bg-typescript"
                                : language === "CSS"
                                  ? "bg-css"
                                  : ""
                          } w-2 h-2 rounded-full`}
                        />
                        <span>{language}</span>
                      </div>
                    </div>
                  </div>
                </li>
              ),
            )
          }
        </ol>
      </Card>
      <Card title="Sponsors">
        <p class="my-3">Thank you for your support 🥰</p>
        <div class="flex flex-wrap sm:gap-2 gap-1">
          {
            sponsors.current.map(({ name, href, avatar }) => (
              <Link name={name} href={href}>
                <Image
                  src={avatar}
                  alt={name}
                  className="rounded-full w-12 h-12"
                  width={12 * 4}
                  height={12 * 4}
                />
              </Link>
            ))
          }
          {
            sponsors.past.map(({ name, href, avatar }) => (
              <Link
                href={
                  href.includes("https://docs.github.com/sponsors")
                    ? "https://github.com"
                    : href
                }
                name={name ?? "private user"}
              >
                <Image
                  src={avatar ?? ""}
                  alt={name ?? "private user"}
                  className="rounded-full w-12 h-12"
                  width={12 * 4}
                  height={12 * 4}
                />
              </Link>
            ))
          }
        </div>
      </Card>
    </div>
  </MainLayout>
</Layout>
