{
  "name": "@hiroppy/site",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.18.0"
  },
  "scripts": {
    "setup": "git config --local core.hooksPath .githooks && npm run corepack",
    "corepack": "corepack enable pnpm",
    "dev": "pnpm copy-images && next dev --webpack",
    "build": "pnpm copy-images && next build --webpack",
    "start": "NODE_ENV=production next start",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:a11y": "playwright test --project=*-a11y",
    "test:routes": "playwright test --project=chrome-routes",
    "test:vrt:update": "docker compose -f compose.vrt.yml up --build && pnpm docker:clean",
    "test:vrt:ci": "playwright test --project=*-vrt-*",
    "test:vrt:ci:update": "pnpm test:vrt:ci --update-snapshots",
    "test:vrt:ci:pages": "playwright test --project=*-vrt-pages",
    "test:vrt:ci:components": "playwright test --project=*-vrt-components",
    "typecheck": "next typegen && tsc --noEmit",
    "fmt": "prettier -w .",
    "fmt:check": "prettier --check .",
    "lint": "knip",
    "lh": "lhci autorun",
    "index": "node --experimental-strip-types scripts/updateBlogOnAlgolia.mts",
    "copy-images": "node --experimental-strip-types scripts/copyHiroppyImages.mts",
    "docker:clean": "docker compose -f compose.vrt.yml down --rmi all --volumes && docker image prune -f"
  },
  "dependencies": {
    "@expressive-code/plugin-collapsible-sections": "0.44.0",
    "@expressive-code/plugin-line-numbers": "0.44.0",
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "16.2.10",
    "@next/third-parties": "16.2.10",
    "@tailwindcss/postcss": "4.3.2",
    "algoliasearch": "5.55.2",
    "cheerio": "1.2.0",
    "clsx": "2.1.1",
    "feed": "5.2.1",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.3",
    "hiroppy": "1.0.77",
    "next": "16.2.10",
    "octokit": "5.0.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "5.7.0",
    "react-markdown": "10.1.0",
    "rehype-expressive-code": "0.44.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.2",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/mdast": "4.0.4",
    "@types/mdx": "2.0.14",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "knip": "6.26.0",
    "lefthook": "2.1.10",
    "postcss": "8.5.19",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "remark": "15.0.1",
    "remark-frontmatter": "5.0.0",
    "remark-mdx-frontmatter": "5.2.0",
    "strip-markdown": "6.0.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "unist-util-visit": "5.1.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
