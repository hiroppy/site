{
  "name": "@hiroppy/site",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": "24.11.1"
  },
  "scripts": {
    "setup": "git config --local core.hooksPath .githooks && npm run corepack",
    "corepack": "corepack enable pnpm",
    "copy-images": "node --experimental-strip-types scripts/copyHiroppyImages.mts",
    "dev": "pnpm copy-images && next dev --webpack",
    "build": "pnpm copy-images && next build --webpack",
    "build:local": "pnpm copy-images && NODE_ENV=test next build --webpack",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:a11y": "NODE_ENV=test playwright test --project=*-a11y",
    "test:vrt:update": "docker compose -f compose.vrt.yml up --build && pnpm docker:clean",
    "test:vrt:ci": "NODE_ENV=test playwright test --project=*-vrt-*",
    "test:vrt:ci:update": "pnpm test:vrt:ci --update-snapshots",
    "test:vrt:ci:pages": "NODE_ENV=test playwright test --project=*-vrt-pages",
    "test:vrt:ci:components": "NODE_ENV=test playwright test --project=*-vrt-components",
    "docker:clean": "docker compose -f compose.vrt.yml down --rmi all --volumes && docker image prune -f",
    "fmt": "prettier -w .",
    "fmt:check": "prettier --check .",
    "lint": "knip",
    "lh": "lhci autorun",
    "index": "node --experimental-strip-types scripts/updateBlogOnAlgolia.mts"
  },
  "dependencies": {
    "@expressive-code/plugin-collapsible-sections": "0.41.3",
    "@expressive-code/plugin-line-numbers": "0.41.3",
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "16.0.6",
    "@next/third-parties": "16.0.7",
    "@tailwindcss/postcss": "4.1.17",
    "algoliasearch": "5.45.0",
    "clsx": "2.1.1",
    "github-slugger": "2.0.0",
    "gray-matter": "4.0.3",
    "hiroppy": "1.0.56",
    "instantsearch.js": "4.84.0",
    "next": "16.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "10.1.0",
    "rehype-expressive-code": "0.41.3",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "shiki": "3.18.0",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.0",
    "@iconify-json/mdi": "1.2.3",
    "@iconify-json/noto": "1.2.7",
    "@iconify/react": "6.0.2",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.57.0",
    "@tailwindcss/vite": "4.1.17",
    "@trivago/prettier-plugin-sort-imports": "6.0.0",
    "@types/mdast": "4.0.4",
    "@types/mdx": "2.0.13",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "@vitest/browser-playwright": "4.0.15",
    "babel-plugin-react-compiler": "1.0.0",
    "cheerio": "1.1.2",
    "knip": "5.71.0",
    "lefthook": "2.0.5",
    "octokit": "5.0.5",
    "postcss": "8.5.6",
    "prettier": "3.7.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "remark": "15.0.1",
    "remark-frontmatter": "5.0.0",
    "strip-markdown": "6.0.0",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "unist-util-visit": "5.0.0",
    "vitest": "4.0.15",
    "yaml": "2.8.2"
  }
}
